<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Date_of_Birth_Validation</fullName>
    <active>true</active>
    <description>Ensures applicants are at least 16 years old.</description>
    <errorConditionFormula>Date_of_Birth__c &gt; TODAY() - (365 * 16)</errorConditionFormula>
    <errorDisplayField>Date_of_Birth__c</errorDisplayField>
    <errorMessage>Student must be at least 16 years old.</errorMessage>
</ValidationRule>
