<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Admission Executive Access</label>
    <description>Grants admission executives the ability to create and manage student applications, upload documents, and view course and admission records.</description>
    <hasActivationRequired>false</hasActivationRequired>
    <classAccesses>
        <apexClass>AdmissionController</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>CourseController</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>DashboardController</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>StudentApplicationController</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <applicationVisibilities>
        <application>Student_Application_Management</application>
        <visible>true</visible>
    </applicationVisibilities>

    <!-- Student Application: Full CRUD -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Student_Application__c</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- Document: Create + Edit (upload & manage docs) -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Document__c</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- Course: Read only -->
    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Course__c</object>
        <viewAllRecords>true</viewAllRecords>
    </objectPermissions>

    <!-- Admission: Read only -->
    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Admission__c</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- Payment: Read only -->
    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Payment__c</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- Tab visibility -->
    <tabSettings>
        <tab>Student_Application__c</tab>
        <visibility>Available</visibility>
    </tabSettings>
    <tabSettings>
        <tab>Document__c</tab>
        <visibility>Available</visibility>
    </tabSettings>
    <tabSettings>
        <tab>Course__c</tab>
        <visibility>Available</visibility>
    </tabSettings>
    <tabSettings>
        <tab>Admission__c</tab>
        <visibility>Available</visibility>
    </tabSettings>

    <!-- Student Application fields (optional/picklist fields only) -->
    <fieldPermissions>
        <editable>true</editable>
        <field>Student_Application__c.Phone__c</field>
        <readable>true</readable>
    </fieldPermissions>

    <fieldPermissions>
        <editable>true</editable>
        <field>Student_Application__c.Application_Status__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Student_Application__c.Document_Status__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Student_Application__c.Admission_Status__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Student_Application__c.Payment_Status__c</field>
        <readable>true</readable>
    </fieldPermissions>

    <!-- Document fields -->
    <fieldPermissions>
        <editable>true</editable>
        <field>Document__c.Document_Type__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Document__c.Verification_Status__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Document__c.Rejection_Reason__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Document__c.Verified_By__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Course__c.Credits__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Course__c.Description__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Course__c.Fees__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Course__c.Status__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Course__c.Type__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Payment__c.Admission__c</field>
        <readable>true</readable>
    </fieldPermissions>

    <fieldPermissions>
        <editable>false</editable>
        <field>Payment__c.Course__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Payment__c.Payment_Date__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Payment__c.Payment_Method__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Payment__c.Payment_Number__c</field>
        <readable>true</readable>
    </fieldPermissions>

    <fieldPermissions>
        <editable>false</editable>
        <field>Payment__c.Receipt_Number__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Payment__c.Remarks__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Payment__c.Student__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Payment__c.Transaction_Id__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <!-- Record Types -->
    <recordTypeVisibilities>
        <recordType>Student_Application__c.Undergraduate</recordType>
        <visible>true</visible>
    </recordTypeVisibilities>
    <recordTypeVisibilities>
        <recordType>Student_Application__c.Postgraduate</recordType>
        <visible>true</visible>
    </recordTypeVisibilities>
    <recordTypeVisibilities>
        <recordType>Student_Application__c.Diploma</recordType>
        <visible>true</visible>
    </recordTypeVisibilities>
    <!-- User System Permissions -->
    <userPermissions>
        <enabled>true</enabled>
        <name>RunReports</name>
    </userPermissions>
    <userPermissions>
        <enabled>true</enabled>
        <name>ViewPublicReports</name>
    </userPermissions>
    <userPermissions>
        <enabled>true</enabled>
        <name>ViewPublicDashboards</name>
    </userPermissions>
</PermissionSet>
