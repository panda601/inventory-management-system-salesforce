<apex:page standardController="Admission__c" renderAs="pdf" applyHtmlTag="false" showHeader="false" sidebar="false" standardStylesheets="false">
    <html>
        <head>
            <style>
                @page {
                    size: letter portrait;
                    margin: 0.6in;
                    @bottom-center {
                        content: "Page 1 of 1 - Official Registrar Record";
                        font-family: Arial, sans-serif;
                        font-size: 8pt;
                        color: #94a3b8;
                    }
                }
                body {
                    font-family: Arial, sans-serif;
                    color: #1e293b;
                    background-color: #ffffff;
                    margin: 0;
                    padding: 0;
                }
                .cert-border {
                    border: 10px double #1B365D;
                    padding: 30px;
                    height: 94%;
                    position: relative;
                }
                .cert-header {
                    text-align: center;
                    margin-bottom: 40px;
                }
                .institution-name {
                    font-size: 26pt;
                    font-weight: bold;
                    color: #1B365D;
                    margin: 0 0 5px 0;
                    letter-spacing: 1px;
                }
                .institution-tagline {
                    font-size: 11pt;
                    color: #64748b;
                    text-transform: uppercase;
                    letter-spacing: 2px;
                    margin: 0;
                }
                .cert-title-section {
                    text-align: center;
                    margin-bottom: 50px;
                }
                .cert-title {
                    font-size: 18pt;
                    font-weight: bold;
                    color: #C5A059;
                    text-transform: uppercase;
                    margin: 0 0 10px 0;
                    letter-spacing: 1px;
                }
                .divider-line {
                    width: 60%;
                    height: 2px;
                    background-color: #C5A059;
                    margin: 0 auto;
                }
                .cert-body {
                    font-size: 12pt;
                    line-height: 1.6;
                    margin-bottom: 50px;
                }
                .cert-intro {
                    text-align: center;
                    margin-bottom: 40px;
                    color: #475569;
                    font-style: italic;
                }
                .details-table {
                    width: 100%;
                    border-collapse: collapse;
                    margin-bottom: 40px;
                }
                .details-table th {
                    background-color: #f8fafc;
                    border-bottom: 2px solid #1B365D;
                    color: #1B365D;
                    font-size: 11pt;
                    text-transform: uppercase;
                    letter-spacing: 0.5px;
                    padding: 10px;
                    text-align: left;
                }
                .details-table td {
                    padding: 12px 10px;
                    border-bottom: 1px solid #e2e8f0;
                    font-size: 11pt;
                }
                .label-cell {
                    font-weight: bold;
                    color: #475569;
                    width: 30%;
                }
                .value-cell {
                    color: #0f172a;
                }
                .highlight-val {
                    font-weight: bold;
                    color: #1B365D;
                }
                .footer-section {
                    margin-top: 60px;
                    width: 100%;
                }
                .signature-block {
                    float: right;
                    width: 200px;
                    text-align: center;
                }
                .signature-line {
                    border-top: 1px solid #64748b;
                    margin-top: 40px;
                    padding-top: 5px;
                    font-size: 9pt;
                    color: #64748b;
                    text-transform: uppercase;
                }
                .seal-block {
                    float: left;
                    width: 150px;
                    text-align: center;
                }
                .seal-text {
                    font-size: 8pt;
                    color: #94a3b8;
                    margin-top: 10px;
                    text-transform: uppercase;
                }
            </style>
        </head>
        <body>
            <div class="cert-border">
                <!-- Header Branding -->
                <div class="cert-header">
                    <h1 class="institution-name">STUDENT PORTAL ACADEMY</h1>
                    <p class="institution-tagline">Office of the Registrar &amp; Admissions</p>
                </div>
                
                <!-- Title -->
                <div class="cert-title-section">
                    <h2 class="cert-title">Certificate of Admission</h2>
                    <div class="divider-line"></div>
                </div>
                
                <!-- Body -->
                <div class="cert-body">
                    <p class="cert-intro">This certifies that the candidate listed below has been officially admitted and registered for study.</p>
                    
                    <!-- Details Table -->
                    <table class="details-table">
                        <thead>
                            <tr>
                                <th colspan="2">Student Information</th>
                                <th colspan="2">Academic Program</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td class="label-cell">Student Name</td>
                                <td class="value-cell highlight-val">{!Admission__c.Student_Name__c}</td>
                                <td class="label-cell">Applied Course</td>
                                <td class="value-cell highlight-val">{!Admission__c.Course__r.Name}</td>
                            </tr>
                            <tr>
                                <td class="label-cell">Enrollment No</td>
                                <td class="value-cell highlight-val">{!Admission__c.Enrollment_Number__c}</td>
                                <td class="label-cell">Course Code</td>
                                <td class="value-cell">{!Admission__c.Course__r.Course_Code__c}</td>
                            </tr>
                            <tr>
                                <td class="label-cell">Email Address</td>
                                <td class="value-cell">{!Admission__c.Student_Application__r.Email__c}</td>
                                <td class="label-cell">Course Credits</td>
                                <td class="value-cell">{!Admission__c.Course__r.Credits__c} Credits</td>
                            </tr>
                            <tr>
                                <td class="label-cell">Phone Number</td>
                                <td class="value-cell">{!Admission__c.Student_Application__r.Phone__c}</td>
                                <td class="label-cell">Tuition Rate</td>
                                <td class="value-cell">${!Admission__c.Course__r.Fees__c}</td>
                            </tr>
                            <tr>
                                <td class="label-cell">Admission Date</td>
                                <td class="value-cell">
                                    <apex:outputText value="{0,date,MMMM d, yyyy}">
                                        <apex:param value="{!Admission__c.Admission_Date__c}" />
                                    </apex:outputText>
                                </td>
                                <td class="label-cell">Tuition Status</td>
                                <td class="value-cell">
                                    <apex:outputText value="{!IF(Admission__c.Fees_Paid__c, 'Paid', 'Pending Payment')}" />
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                
                <!-- Signatures / Footer -->
                <div class="footer-section">
                    <div class="seal-block">
                        <div style="font-size: 24pt; color: #C5A059;">★</div>
                        <div class="seal-text">Official Registrar<br/>Digital Security Seal</div>
                    </div>
                    
                    <div class="signature-block">
                        <div style="font-family: 'Georgia', serif; font-size: 14pt; font-style: italic; color: #1B365D;">Office of Admissions</div>
                        <div class="signature-line">Authorized Signatory</div>
                    </div>
                </div>
            </div>
        </body>
    </html>
</apex:page>
