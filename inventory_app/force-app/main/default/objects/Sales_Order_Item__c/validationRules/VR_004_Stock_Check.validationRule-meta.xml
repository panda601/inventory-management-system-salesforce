<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>VR_004_Stock_Check</fullName>
    <active>true</active>
    <errorConditionFormula>ISPICKVAL(Sales_Order__r.Status__c, "Confirmed") &amp;&amp; (Product__r.Current_Stock__c &lt; Quantity__c)</errorConditionFormula>
    <errorDisplayField>Quantity__c</errorDisplayField>
    <errorMessage>Insufficient Stock Available</errorMessage>
</ValidationRule>
