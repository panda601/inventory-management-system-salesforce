# Salesforce Org Configuration
SF_USERNAME=your_username@example.com
SF_INSTANCE_URL=https://login.salesforce.com

# Connected App Authentication (JWT Flow)
SF_CLIENT_ID=your_connected_app_consumer_key
SF_JWT_KEY_FILE=config/server.key

# Connected App Authentication (Web Server Flow)
SF_CLIENT_SECRET=your_connected_app_consumer_secret

# Scratch Org Config
SF_DEV_HUB_USERNAME=your_dev_hub@example.com
