<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Document Verifier Access</label>
    <description>Grants document verification staff the ability to review and update document verification status. Read-only on student applications.</description>
    <hasActivationRequired>false</hasActivationRequired>
    <applicationVisibilities>
        <application>Student_Application_Management</application>
        <visible>true</visible>
    </applicationVisibilities>
    <!-- Document: Read + Edit -->
    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Document__c</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>
    <!-- Student Application: Read only -->
    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Student_Application__c</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>
    <tabSettings>
        <tab>Document__c</tab>
        <visibility>Available</visibility>
    </tabSettings>
    <tabSettings>
        <tab>Student_Application__c</tab>
        <visibility>Available</visibility>
    </tabSettings>
    <!-- Document fields -->
    <fieldPermissions>
        <editable>false</editable>
        <field>Document__c.Document_Type__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Document__c.Verification_Status__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Document__c.Rejection_Reason__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Document__c.Verified_By__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <!-- Student Application non-required fields (read only) -->
    <fieldPermissions>
        <editable>false</editable>
        <field>Student_Application__c.Application_Status__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Student_Application__c.Document_Status__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Student_Application__c.Admission_Status__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Student_Application__c.Phone__c</field>
        <readable>true</readable>
    </fieldPermissions>
</PermissionSet>
