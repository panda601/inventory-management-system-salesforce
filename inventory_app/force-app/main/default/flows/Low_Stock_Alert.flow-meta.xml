<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>65.0</apiVersion>
    <environments>Default</environments>
    <interviewLabel>Low Stock Alert {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Low Stock Alert</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <decisions>
        <name>Is_Low_Stock</name>
        <label>Is Low Stock?</label>
        <locationX>176</locationX>
        <locationY>300</locationY>
        <defaultConnectorLabel>Stock OK</defaultConnectorLabel>
        <rules>
            <name>Low_Stock_Triggered</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Current_Stock__c</leftValueReference>
                <operator>LessThan</operator>
                <rightValue>
                    <elementReference>$Record.Minimum_Stock__c</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Inventory_Manager</targetReference>
            </connector>
            <label>Low Stock Triggered</label>
        </rules>
    </decisions>
    <recordCreates>
        <name>Create_Alert_Task</name>
        <label>Create Alert Task</label>
        <locationX>300</locationX>
        <locationY>500</locationY>
        <inputAssignments>
            <field>Description</field>
            <value>
                <stringValue>Product stock has fallen below the minimum stock level. Current Stock: {!$Record.Current_Stock__c}, Minimum Stock: {!$Record.Minimum_Stock__c}</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>OwnerId</field>
            <value>
                <elementReference>Get_Inventory_Manager.Id</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Priority</field>
            <value>
                <stringValue>High</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Status</field>
            <value>
                <stringValue>Not Started</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Subject</field>
            <value>
                <stringValue>Low Stock Alert: {!$Record.Name}</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>WhatId</field>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </inputAssignments>
        <object>Task</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordCreates>
    <recordLookups>
        <name>Get_Inventory_Manager</name>
        <label>Get Inventory Manager</label>
        <locationX>300</locationX>
        <locationY>400</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Create_Alert_Task</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Username</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>backuproy0911.salesexec@inventory.app.com</stringValue>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>User</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <start>
        <locationX>50</locationX>
        <locationY>50</locationY>
        <connector>
            <targetReference>Is_Low_Stock</targetReference>
        </connector>
        <object>Product__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
