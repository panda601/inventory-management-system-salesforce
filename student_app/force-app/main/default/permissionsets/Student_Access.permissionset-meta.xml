    </fieldPermissions>
    <!-- Record Types -->
    <recordTypeVisibilities>
        <recordType>Student_Application__c.Undergraduate</recordType>
        <visible>true</visible>
    </recordTypeVisibilities>
    <recordTypeVisibilities>
        <recordType>Student_Application__c.Postgraduate</recordType>
        <visible>true</visible>
    </recordTypeVisibilities>
    <recordTypeVisibilities>
        <recordType>Student_Application__c.Diploma</recordType>
