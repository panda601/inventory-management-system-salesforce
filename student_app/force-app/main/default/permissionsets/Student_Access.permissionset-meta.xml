<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Student Access</label>
    <description>Production-ready Student security model permission set. Grants students least-privilege access to manage their own applications and documents, and view payments, courses, and admissions.</description>
    <hasActivationRequired>false</hasActivationRequired>
    <classAccesses>
        <apexClass>AdmissionController</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>CourseController</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>DashboardController</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>StudentApplicationController</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <applicationVisibilities>
        <application>Student_Application_Management</application>
        <visible>true</visible>
    </applicationVisibilities>
    <!-- Object Permissions -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Student_Application__c</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Document__c</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>
    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Payment__c</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>
    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Admission__c</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>
    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Course__c</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>
    <!-- Tab Settings -->
    <tabSettings>
        <tab>Student_Application__c</tab>
        <visibility>Available</visibility>
    </tabSettings>
    <tabSettings>
        <tab>Document__c</tab>
        <visibility>Available</visibility>
    </tabSettings>
    <tabSettings>
        <tab>Payment__c</tab>
        <visibility>Available</visibility>
    </tabSettings>
    <tabSettings>
        <tab>Course__c</tab>
        <visibility>Available</visibility>
    </tabSettings>
    <tabSettings>
        <tab>Admission__c</tab>
        <visibility>Available</visibility>
    </tabSettings>
    <!-- Field-Level Security -->
    <!-- Student Application fields -->
    <fieldPermissions>
        <editable>true</editable>
        <field>Student_Application__c.Phone__c</field>
        <readable>true</readable>
     </fieldPermissions>

    <fieldPermissions>
        <editable>true</editable>
        <field>Student_Application__c.Application_Status__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Student_Application__c.Document_Status__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Student_Application__c.Payment_Status__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Student_Application__c.Admission_Status__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <!-- Document fields -->
    <fieldPermissions>
        <editable>true</editable>
        <field>Document__c.Document_Type__c</field>
